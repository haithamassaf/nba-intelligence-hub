# ── Optional: Claude prose for team summaries ────────────────────────
# The app runs fully without this. With it, summaries are written by Claude,
# phrasing only the computed grades (never the source of any number).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── Optional: college stats for NFL rookie grading ───────────────────
# Free key from https://collegefootballdata.com/key (email request).
# Without it, rookies grade on draft capital + combine only.
CFBD_API_KEY=

# ── Season overrides (all optional; sensible defaults auto-detect) ────
# Most recent completed season drives stats/grading.
NBA_STATS_SEASON=2025-26
# NFL_STATS_SEASON=2025      # last completed season (auto-detected if unset)
# NFL_ROSTER_SEASON=2026     # current league year, rosters incl. rookies
# NFL_DRAFT_YEAR=2026        # rookie draft class
COLLEGE_SEASON=2025          # the season the current rookie class last played

# NFL trade simulator: current league-year salary cap in $M (set to the live cap
# for exact cap room; net cap change between teams is exact regardless).
NFL_SALARY_CAP=300.0

# NBA_API_TIMEOUT=30
