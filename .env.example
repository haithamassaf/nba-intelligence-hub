# All optional; sensible defaults auto-detect.

# Optional: Claude writes the trade opinion (the app runs without it).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# NBA: most recent completed season (rosters + stats).
NBA_STATS_SEASON=2025-26
# NBA_API_TIMEOUT=30

# NFL season overrides (auto-detected if unset).
# NFL_STATS_SEASON=2025      # last completed season
# NFL_ROSTER_SEASON=2026     # current league year, rosters incl. rookies

# NFL trade simulator: current league-year salary cap in $M. Set to the live cap
# for exact room; net cap change between teams is exact regardless.
NFL_SALARY_CAP=300.0
